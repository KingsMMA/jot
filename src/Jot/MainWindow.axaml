<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ae="https://github.com/avaloniaui/avaloniaedit"
        x:Class="Jot.MainWindow"
        Width="1000" Height="700"
        Title="Jot"
        Background="#0d1117">
    <DockPanel>
        <Border DockPanel.Dock="Bottom" Background="#161b22" Height="24" Padding="8,0">
            <Grid ColumnDefinitions="*,Auto">
                <TextBlock Grid.Column="0" Name="StatusPath" VerticalAlignment="Center"
                           Foreground="#8b949e" FontSize="12" TextTrimming="CharacterEllipsis" />
                <TextBlock Grid.Column="1" Name="StatusInfo" VerticalAlignment="Center"
                           Foreground="#8b949e" FontSize="12" />
            </Grid>
        </Border>

        <ae:TextEditor Name="Editor"
                       FontFamily="Cascadia Code,Consolas,Menlo,monospace"
                       FontSize="13"
                       ShowLineNumbers="True"
                       Background="#0d1117"
                       Foreground="#e6edf3"
                       HorizontalScrollBarVisibility="Auto"
                       VerticalScrollBarVisibility="Auto" />
    </DockPanel>
</Window>
