<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ae="https://github.com/avaloniaui/avaloniaedit"
        xmlns:search="clr-namespace:Jot.Search"
        x:Class="Jot.MainWindow"
        Width="1000" Height="700"
        Title="Jot"
        Background="#0d1117">
    <DockPanel>
        <Border DockPanel.Dock="Bottom" Background="#161b22" Height="26" Padding="8,0">
            <Grid ColumnDefinitions="*,Auto,Auto">
                <TextBlock Grid.Column="0" Name="StatusPath" VerticalAlignment="Center"
                           Foreground="#8b949e" FontSize="12" TextTrimming="CharacterEllipsis" />
                <TextBlock Grid.Column="1" Name="StatusInfo" VerticalAlignment="Center"
                           Margin="0,0,12,0" Foreground="#8b949e" FontSize="12" />
                <ComboBox Grid.Column="2" Name="LanguagePicker" VerticalAlignment="Center"
                          MinWidth="130" FontSize="12" Background="Transparent" BorderThickness="0"
                          ToolTip.Tip="Language (overrides auto-detection)" />
            </Grid>
        </Border>

        <Grid Name="EditorGrid" ColumnDefinitions="*,Auto,0">
            <Panel Grid.Column="0">
                <ae:TextEditor Name="Editor"
                               FontFamily="Cascadia Code,Consolas,Menlo,monospace"
                               FontSize="13"
                               ShowLineNumbers="True"
                               Background="#0d1117"
                               Foreground="#e6edf3"
                               HorizontalScrollBarVisibility="Auto"
                               VerticalScrollBarVisibility="Auto" />
                <search:SearchReplacePanel Name="SearchPanel"
                                           HorizontalAlignment="Right" VerticalAlignment="Top" />
            </Panel>
            <GridSplitter Grid.Column="1" Name="PreviewSplitter" Width="4"
                          Background="#21262d" IsVisible="False" />
            <Border Grid.Column="2" Name="PreviewHost" Background="#0d1117" />
        </Grid>
    </DockPanel>
</Window>
