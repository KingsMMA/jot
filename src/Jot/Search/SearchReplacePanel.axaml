<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="Jot.Search.SearchReplacePanel"
             IsVisible="False">
    <Border Background="#1c2128" BorderBrush="#30363d" BorderThickness="1" CornerRadius="6"
            Padding="6" Margin="0,8,18,0" BoxShadow="0 4 16 0 #80000000">
        <Grid RowDefinitions="Auto,Auto" ColumnDefinitions="Auto,Auto,Auto">
            <!-- Find row -->
            <TextBox Grid.Row="0" Grid.Column="0" Name="FindBox" Width="220" Height="28"
                     Watermark="Find" FontSize="12" VerticalContentAlignment="Center" />
            <StackPanel Grid.Row="0" Grid.Column="1" Orientation="Horizontal" Margin="6,0" Spacing="2"
                        VerticalAlignment="Center">
                <ToggleButton Name="CaseToggle" Content="Aa" Width="30" Height="28" FontSize="12"
                              Padding="0" ToolTip.Tip="Match case" />
                <ToggleButton Name="WordToggle" Content="W" Width="30" Height="28" FontSize="12"
                              Padding="0" ToolTip.Tip="Whole word" />
                <ToggleButton Name="RegexToggle" Content=".*" Width="30" Height="28" FontSize="12"
                              Padding="0" ToolTip.Tip="Regular expression" />
            </StackPanel>
            <StackPanel Grid.Row="0" Grid.Column="2" Orientation="Horizontal" Spacing="2"
                        VerticalAlignment="Center">
                <TextBlock Name="CountText" VerticalAlignment="Center" Margin="2,0,6,0"
                           Foreground="#8b949e" FontSize="11" MinWidth="64" />
                <Button Name="PrevButton" Content="↑" Width="30" Height="28" Padding="0"
                        ToolTip.Tip="Previous (Shift+Enter)" />
                <Button Name="NextButton" Content="↓" Width="30" Height="28" Padding="0"
                        ToolTip.Tip="Next (Enter)" />
                <Button Name="CloseButton" Content="✕" Width="30" Height="28" Padding="0"
                        ToolTip.Tip="Close (Esc)" />
            </StackPanel>

            <!-- Replace row -->
            <TextBox Grid.Row="1" Grid.Column="0" Name="ReplaceBox" Width="220" Height="28"
                     Margin="0,6,0,0" Watermark="Replace" FontSize="12"
                     VerticalContentAlignment="Center" />
            <StackPanel Grid.Row="1" Grid.Column="2" Name="ReplaceActions" Orientation="Horizontal"
                        Spacing="2" Margin="0,6,0,0" VerticalAlignment="Center">
                <Button Name="ReplaceButton" Content="Replace" Height="28" FontSize="12"
                        Padding="8,0" ToolTip.Tip="Replace current match" />
                <Button Name="ReplaceAllButton" Content="All" Height="28" FontSize="12"
                        Padding="8,0" ToolTip.Tip="Replace all matches" />
            </StackPanel>
        </Grid>
    </Border>
</UserControl>
